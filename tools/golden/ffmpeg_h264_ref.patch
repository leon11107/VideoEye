+/* VEYE: exact CABAC bit position. The arithmetic decoder buffers up-to-16
+ * look-ahead bits in cc.low; subtract them from the consumed bytestream. */
+static av_always_inline av_unused int veye_cabac_bits(const CABACContext *c)
+{
+    int lo = c->low & 0xFFFF;
+    int buffered = lo ? (16 - ff_ctz(lo)) : 0;
+    return (int)(c->bytestream - c->bytestream_start) * 8 - buffered;
+}
