+/*!
+ ************************************************************************
+ * \brief
+ *    VideoEye golden dump: emit per-MB qp + prediction type for the
+ *    just-decoded macroblock when VEYE_JM_DUMP names an output CSV.
+ *    pred follows the VideoEye scheme: 1=intra, 2=inter, 3=skip, 4=ipcm.
+ ************************************************************************
+ */
+static void veyeDumpMb(Slice *currSlice)
+{
+  static FILE *vf = NULL;
+  static int   tried = 0;
+  static struct storable_picture *last_pic = NULL;
+  static int   decidx = -1;
+  Macroblock *currMB;
+  int pred;
+
+  if (vf == NULL)
+  {
+    const char *path;
+    if (tried)
+      return;
+    tried = 1;
+    path = getenv("VEYE_JM_DUMP");
+    if (path == NULL)
+      return;
+    vf = fopen(path, "w");
+    if (vf == NULL)
+      return;
+    fprintf(vf, "decidx,poc,x,y,qp,pred,mb_type\n");
+  }
+
+  if (currSlice->dec_picture == NULL)
+    return;
+
+  if (currSlice->dec_picture != last_pic)
+  {
+    last_pic = currSlice->dec_picture;
+    ++decidx;
+  }
+
+  currMB = &currSlice->mb_data[currSlice->current_mb_nr];
+
+  if (currMB->mb_type == IPCM)
+    pred = 4;
+  else if (currMB->is_intra_block)
+    pred = 1;
+  else if (currMB->skip_flag)
+    pred = 3;
+  else
+    pred = 2;
+
+  fprintf(vf, "%d,%d,%d,%d,%d,%d,%d\n",
+          decidx, currSlice->dec_picture->poc, currMB->pix_x, currMB->pix_y,
+          currMB->qp, pred, (int)currMB->mb_type);
+}
+
