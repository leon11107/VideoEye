diff --git a/aom/aomdx.h b/aom/aomdx.h
index f18cbbfab9..5c6d2bd6ae 100644
--- a/aom/aomdx.h
+++ b/aom/aomdx.h
@@ -466,6 +466,13 @@ enum aom_dec_control_id {
    * be used.
    */
   AV1D_GET_MI_INFO,
+
+  /*!\brief Codec control function to get the order hint of the most recently
+   * *output* frame (the one returned by the last aom_codec_get_frame), as
+   * opposed to AOMD_GET_ORDER_HINT which returns the most recently *decoded*
+   * frame. unsigned int* parameter. (VideoEye extension.)
+   */
+  AOMD_GET_LAST_SHOW_ORDER_HINT,
 };
 
 /*!\cond */
@@ -595,6 +602,9 @@ AOM_CTRL_USE_TYPE(AOMD_GET_BASE_Q_IDX, int *)
 AOM_CTRL_USE_TYPE(AOMD_GET_ORDER_HINT, unsigned int *)
 #define AOM_CTRL_AOMD_GET_ORDER_HINT
 
+AOM_CTRL_USE_TYPE(AOMD_GET_LAST_SHOW_ORDER_HINT, unsigned int *)
+#define AOM_CTRL_AOMD_GET_LAST_SHOW_ORDER_HINT
+
 // The AOM_CTRL_USE_TYPE macro can't be used with AV1D_GET_MI_INFO because
 // AV1D_GET_MI_INFO takes more than one parameter.
 #define AOM_CTRL_AV1D_GET_MI_INFO
diff --git a/av1/av1_dx_iface.c b/av1/av1_dx_iface.c
index 77769bd1d5..4449c88dd9 100644
--- a/av1/av1_dx_iface.c
+++ b/av1/av1_dx_iface.c
@@ -548,6 +548,14 @@ static aom_codec_err_t decode_one(aom_codec_alg_priv_t *ctx,
 
   frame_worker_data->pbi->is_annexb = ctx->is_annexb;
 
+#if CONFIG_INSPECTION
+  // VideoEye: propagate the inspection callback on the normal decode path too,
+  // not just decoder_inspect(). This lets a caller using the standard
+  // aom_codec_decode()/aom_codec_get_frame() API receive per-frame inspection.
+  frame_worker_data->pbi->inspect_cb = ctx->inspect_cb;
+  frame_worker_data->pbi->inspect_ctx = ctx->inspect_ctx;
+#endif
+
   worker->had_error = 0;
   winterface->execute(worker);
 
@@ -1498,6 +1506,17 @@ static aom_codec_err_t ctrl_get_order_hint(aom_codec_alg_priv_t *ctx,
   return AOM_CODEC_OK;
 }
 
+// VideoEye: order hint of the most recently OUTPUT frame (set in
+// decoder_get_frame), not the most recently decoded one.
+static aom_codec_err_t ctrl_get_last_show_order_hint(aom_codec_alg_priv_t *ctx,
+                                                     va_list args) {
+  unsigned int *const arg = va_arg(args, unsigned int *);
+  if (arg == NULL) return AOM_CODEC_INVALID_PARAM;
+  if (ctx->last_show_frame == NULL) return AOM_CODEC_ERROR;
+  *arg = ctx->last_show_frame->order_hint;
+  return AOM_CODEC_OK;
+}
+
 static aom_codec_err_t ctrl_get_mi_info(aom_codec_alg_priv_t *ctx,
                                         va_list args) {
   int mi_row = va_arg(args, int);
@@ -1714,6 +1733,7 @@ static aom_codec_ctrl_fn_map_t decoder_ctrl_maps[] = {
   { AOMD_GET_SHOW_FRAME_FLAG, ctrl_get_show_frame_flag },
   { AOMD_GET_BASE_Q_IDX, ctrl_get_base_q_idx },
   { AOMD_GET_ORDER_HINT, ctrl_get_order_hint },
+  { AOMD_GET_LAST_SHOW_ORDER_HINT, ctrl_get_last_show_order_hint },
   { AV1D_GET_MI_INFO, ctrl_get_mi_info },
   CTRL_MAP_END,
 };
diff --git a/av1/decoder/inspection.c b/av1/decoder/inspection.c
index f84ed17d20..2909cd6669 100644
--- a/av1/decoder/inspection.c
+++ b/av1/decoder/inspection.c
@@ -16,6 +16,7 @@
 #include "av1/decoder/inspection.h"
 #include "av1/common/enums.h"
 #include "av1/common/cdef.h"
+#include "av1/common/quant_common.h"  // VideoEye: av1_get_qindex (segment QP)
 
 static void ifd_init_mi_rc(insp_frame_data *fd, int mi_cols, int mi_rows) {
   fd->mi_cols = mi_cols;
@@ -64,6 +65,22 @@ int ifd_inspect(insp_frame_data *fd, void *decoder, int skip_not_transform) {
   fd->tile_mi_rows = tile_info.mi_row_end - tile_info.mi_row_start;
   fd->delta_q_present_flag = cm->delta_q_info.delta_q_present_flag;
   fd->delta_q_res = cm->delta_q_info.delta_q_res;
+  // VideoEye: capture this frame's order hint and that of each reference slot
+  // so the consumer can draw frame-chart reference markers. order_hint is the
+  // bitstream-coded order hint (the decoder does not compute display_order_hint,
+  // which is encoder-only); it is monotonic within a GOP and may wrap modulo
+  // 2^order_hint_bits, which the consumer resolves by nearest frame index.
+  fd->order_hint = (int)cm->current_frame.order_hint;
+  for (int r = 0; r < INTER_REFS_PER_FRAME; r++) {
+    const RefCntBuffer *ref_buf = get_ref_frame_buf(cm, LAST_FRAME + r);
+    fd->ref_frame_order_hint[r] = ref_buf ? (int)ref_buf->order_hint : -1;
+  }
+  // VideoEye: per-plane loop-restoration frame type (RESTORE_NONE/WIENER/
+  // SGRPROJ/SWITCHABLE) and restoration-unit size. Frame-level, not per-MI.
+  for (int p = 0; p < 3; p++) {
+    fd->lr_type[p] = (int)cm->rst_info[p].frame_restoration_type;
+    fd->lr_unit_size[p] = cm->rst_info[p].restoration_unit_size;
+  }
 #if CONFIG_ACCOUNTING
   fd->accounting = &pbi->accounting;
 #endif
@@ -96,6 +113,13 @@ int ifd_inspect(insp_frame_data *fd, void *decoder, int skip_not_transform) {
       mi->intrabc = (int16_t)mbmi->use_intrabc;
       mi->palette = (int16_t)mbmi->palette_mode_info.palette_size[0];
       mi->uv_palette = (int16_t)mbmi->palette_mode_info.palette_size[1];
+      // VideoEye: filter-intra mode (0..4), or -1 if not used. The block's
+      // y_mode stays DC_PRED when filter-intra is on, so this is the only field
+      // that distinguishes a filter-intra block.
+      mi->filter_intra =
+          mbmi->filter_intra_mode_info.use_filter_intra
+              ? (int16_t)mbmi->filter_intra_mode_info.filter_intra_mode
+              : -1;
       // Prediction Mode for Chromatic planes
       if (mi->mode < INTRA_MODES) {
         mi->uv_mode = mbmi->uv_mode;
@@ -154,8 +178,11 @@ int ifd_inspect(insp_frame_data *fd, void *decoder, int skip_not_transform) {
         mi->cfl_alpha_idx = 0;
         mi->cfl_alpha_sign = 0;
       }
-      // delta_q
-      mi->current_qindex = mbmi->current_qindex;
+      // delta_q + segmentation: mbmi->current_qindex carries only the delta_q
+      // adjustment; fold in the per-segment SEG_LVL_ALT_Q delta so this is the
+      // effective qindex actually used to dequant the block (matches Elecard).
+      mi->current_qindex =
+          av1_get_qindex(&cm->seg, mbmi->segment_id, mbmi->current_qindex);
     }
   }
   return 1;
diff --git a/av1/decoder/inspection.h b/av1/decoder/inspection.h
index 7d1c14db2a..a124255881 100644
--- a/av1/decoder/inspection.h
+++ b/av1/decoder/inspection.h
@@ -55,6 +55,7 @@ struct insp_mi_data {
   int16_t intrabc;
   int16_t palette;
   int16_t uv_palette;
+  int16_t filter_intra;  // VideoEye: filter-intra mode 0..4, -1 if not used
 };
 
 typedef struct insp_frame_data insp_frame_data;
@@ -79,6 +80,17 @@ struct insp_frame_data {
   int delta_q_present_flag;
   int delta_q_res;
   int show_existing_frame;
+  // VideoEye: frame reference relationships (display order). order_hint is this
+  // frame's display order; ref_frame_order_hint[r] is the display order of the
+  // frame in reference slot LAST_FRAME+r (-1 if that slot is unused). 7 ==
+  // INTER_REFS_PER_FRAME (kept as a literal so this header needs no extra
+  // includes; the value is fixed by the AV1 spec).
+  int order_hint;
+  int ref_frame_order_hint[7];
+  // VideoEye: per-plane (Y, U, V) loop-restoration frame type (0..3) and
+  // restoration-unit size in pixels. Frame-level.
+  int lr_type[3];
+  int lr_unit_size[3];
 };
 
