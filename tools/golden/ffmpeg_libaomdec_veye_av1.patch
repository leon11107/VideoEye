+
+            rec->mv0_x = rec->mv0_y = rec->mv1_x = rec->mv1_y = 0;
+            rec->ref0  = rec->ref1  = -1;
+            if (mvf) {
+                const int8_t *ref = (const int8_t *)(mvf + mvf_layout->ref_off);
+                if (pf & 1) {  /* PF_L0 */
+                    const int16_t *m =
+                        (const int16_t *)(mvf + mvf_layout->mv0_off);
+                    rec->mv0_x = m[0];
+                    rec->mv0_y = m[1];
+                    rec->ref0  = ref[0];
+                }
+                if (pf & 2) {  /* PF_L1 */
+                    const int16_t *m =
+                        (const int16_t *)(mvf + mvf_layout->mv1_off);
+                    rec->mv1_x = m[0];
+                    rec->mv1_y = m[1];
+                    rec->ref1  = ref[1];
+                }
+            }
+            rec->reserved[0] = rec->reserved[1] = 0;
+            rec++;
+        }
+    }
+
+    return 0;
+}
+
+/* libaom: ref_frame[0] == INTRA_FRAME (0) marks an intra block; >= 1 is inter.
+ * NONE_FRAME is -1. */
+#define VEYE_AV1_INTRA_FRAME 0
+
+int ff_veye_export_blockinfo_av1(AVFrame *frame,
+                                 const struct veye_insp_frame_data *fd)
+{
+    VeyeBlockInfoHeader *hdr;
+    VeyeBlockRecordAV1 *rec;
+    AVFrameSideData *sd;
+    size_t n, size;
+    int x, y;
+
+    if (!frame || !fd || !fd->mi_grid || fd->mi_cols <= 0 || fd->mi_rows <= 0)
+        return 0;
+
+    n    = (size_t)fd->mi_cols * (size_t)fd->mi_rows;
+    size = sizeof(VeyeBlockInfoHeader) + n * sizeof(VeyeBlockRecordAV1);
+
+    sd = av_frame_new_side_data(frame, AV_FRAME_DATA_VEYE_BLOCKINFO, size);
+    if (!sd)
+        return AVERROR(ENOMEM);
+
+    hdr = (VeyeBlockInfoHeader *)sd->data;
+    hdr->magic       = VEYE_BI_MAGIC;
+    hdr->version     = VEYE_BI_VERSION;
+    hdr->record_size = (uint16_t)sizeof(VeyeBlockRecordAV1);
+    hdr->codec_id    = (uint32_t)AV_CODEC_ID_AV1;
+    hdr->grid_w      = (uint32_t)fd->mi_cols;
+    hdr->grid_h      = (uint32_t)fd->mi_rows;
+    hdr->block_unit  = 4;  /* MI_SIZE: each cell is a 4x4 luma block */
+    hdr->n_records   = (uint32_t)n;
+
+    rec = (VeyeBlockRecordAV1 *)(sd->data + sizeof(VeyeBlockInfoHeader));
+    for (y = 0; y < fd->mi_rows; y++) {
+        for (x = 0; x < fd->mi_cols; x++) {
+            const veye_insp_mi_data *mi = &fd->mi_grid[y * fd->mi_cols + x];
+            int inter = mi->ref_frame[0] > VEYE_AV1_INTRA_FRAME;
+
+            rec->bsize   = (uint8_t)mi->bsize;
+            rec->pred    = (uint8_t)(inter ? VEYE_PRED_INTER : VEYE_PRED_INTRA);
+            rec->mode    = (uint8_t)mi->mode;
+            rec->skip    = (uint8_t)mi->skip;
+            rec->qp      = mi->current_qindex;
+            rec->mv0_x   = mi->mv[0].col;
+            rec->mv0_y   = mi->mv[0].row;
+            rec->mv1_x   = mi->mv[1].col;
+            rec->mv1_y   = mi->mv[1].row;
+            rec->ref0    = (int8_t)mi->ref_frame[0];
+            rec->ref1    = (int8_t)mi->ref_frame[1];
+            rec->tx_size = (uint8_t)mi->tx_size;
+            rec->reserved = 0;
             rec++;
         }
     }
