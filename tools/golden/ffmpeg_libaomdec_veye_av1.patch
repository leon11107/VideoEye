diff --git a/libavcodec/libaomdec.c b/libavcodec/libaomdec.c
index 69eec8b..d8fcab5 100644
--- a/libavcodec/libaomdec.c
+++ b/libavcodec/libaomdec.c
@@ -29,17 +29,62 @@
 #include "libavutil/common.h"
 #include "libavutil/cpu.h"
 #include "libavutil/imgutils.h"
+#include "libavutil/mem.h"
 
 #include "avcodec.h"
 #include "codec_internal.h"
 #include "decode.h"
 #include "libaom.h"
 #include "profiles.h"
+#include "veye_blockinfo.h"
+#include "veye_aom_inspect.h"
+
+/* VideoEye: a small pool of serialized per-frame block grids, keyed by order
+ * hint. An AV1 Temporal Unit can decode several frames (e.g. an ALTREF plus the
+ * shown frame) in one aom_codec_decode(), and frames are output in display
+ * order which differs from decode order -- so the single most-recent inspection
+ * cannot be attached blindly to whatever aom_codec_get_frame() returns. We
+ * serialize every decoded frame here, then attach the one whose order hint
+ * matches the output frame (AOMD_GET_LAST_SHOW_ORDER_HINT). 16 covers the
+ * reorder depth of any real GOP. */
+#define VEYE_POOL_SIZE 16
+
+typedef struct VeyeInspSlot {
+    int valid;
+    unsigned int order_hint;
+    uint8_t *buf;   ///< serialized side-data payload (av_malloc'd)
+    size_t size;
+} VeyeInspSlot;
 
 typedef struct AV1DecodeContext {
     struct aom_codec_ctx decoder;
+    veye_insp_frame_data insp;  ///< VideoEye: scratch for the inspection callback
+    int insp_ready;             ///< inspection callback registered
+    VeyeInspSlot insp_pool[VEYE_POOL_SIZE];  ///< decoded-frame grids by order hint
 } AV1DecodeContext;
 
+/* VideoEye: libaom invokes this once per decoded frame during
+ * aom_codec_decode(). We serialize the block grid immediately and stash it
+ * keyed by this frame's order hint, so it survives until the frame is output
+ * (which may be several get_frame calls later, in display order). */
+static void veye_inspect_cb(void *pbi, void *data)
+{
+    AV1DecodeContext *ctx = (AV1DecodeContext *)data;
+    uint8_t *buf = NULL;
+    size_t size = 0;
+
+    ifd_inspect(&ctx->insp, pbi, 0);
+    if (ff_veye_serialize_blockinfo_av1(&ctx->insp, &buf, &size) == 0 && buf) {
+        VeyeInspSlot *s =
+            &ctx->insp_pool[(unsigned)ctx->insp.order_hint % VEYE_POOL_SIZE];
+        av_free(s->buf);
+        s->buf = buf;
+        s->size = size;
+        s->order_hint = (unsigned int)ctx->insp.order_hint;
+        s->valid = 1;
+    }
+}
+
 static av_cold int aom_init(AVCodecContext *avctx,
                             const struct aom_codec_iface *iface)
 {
@@ -58,6 +103,25 @@ static av_cold int aom_init(AVCodecContext *avctx,
         return AVERROR(EINVAL);
     }
 
+    /* VideoEye: enable per-frame block inspection. ifd_inspect() reallocates
+     * the grid to the real frame dimensions, so the init size is only a hint. */
+    {
+        aom_inspect_init ii;
+        int w = avctx->width  > 0 ? avctx->width  : 64;
+        int h = avctx->height > 0 ? avctx->height : 64;
+        ifd_init(&ctx->insp, w, h);
+        ii.inspect_cb  = veye_inspect_cb;
+        ii.inspect_ctx = ctx;
+        if (aom_codec_control(&ctx->decoder, AV1_SET_INSPECTION_CALLBACK, &ii)
+                == AOM_CODEC_OK) {
+            ctx->insp_ready = 1;
+        } else {
+            av_log(avctx, AV_LOG_WARNING,
+                   "libaom built without inspection; no block info\n");
+            ifd_clear(&ctx->insp);
+        }
+    }
+
     return 0;
 }
 
@@ -180,6 +244,26 @@ static int aom_decode(AVCodecContext *avctx, AVFrame *picture,
         if ((ret = ff_get_buffer(avctx, picture, 0)) < 0)
             return ret;
 
+        /* VideoEye: attach the block grid for the frame we just pulled. The
+         * output frame (display order) may differ from the last decoded frame,
+         * so match by the output frame's order hint against the per-frame pool
+         * filled by the inspection callback. Fall back to the most-recent
+         * inspection only if the lookup fails. */
+        if (ctx->insp_ready) {
+            unsigned int out_oh;
+            int attached = 0;
+            if (aom_codec_control(&ctx->decoder, AOMD_GET_LAST_SHOW_ORDER_HINT,
+                                  &out_oh) == AOM_CODEC_OK) {
+                VeyeInspSlot *s = &ctx->insp_pool[out_oh % VEYE_POOL_SIZE];
+                if (s->valid && s->order_hint == out_oh) {
+                    ff_veye_attach_blockinfo(picture, s->buf, s->size);
+                    attached = 1;
+                }
+            }
+            if (!attached && !ctx->insp.show_existing_frame)
+                ff_veye_export_blockinfo_av1(picture, &ctx->insp);
+        }
+
 #ifdef AOM_CTRL_AOMD_GET_FRAME_FLAGS
         {
             aom_codec_frame_flags_t flags;
@@ -223,7 +307,11 @@ static int aom_decode(AVCodecContext *avctx, AVFrame *picture,
 static av_cold int aom_free(AVCodecContext *avctx)
 {
     AV1DecodeContext *ctx = avctx->priv_data;
+    int i;
     aom_codec_destroy(&ctx->decoder);
+    ifd_clear(&ctx->insp);
+    for (i = 0; i < VEYE_POOL_SIZE; i++)
+        av_freep(&ctx->insp_pool[i].buf);
     return 0;
 }
 
