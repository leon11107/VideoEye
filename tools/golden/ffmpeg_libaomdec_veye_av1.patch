@@ -142,28 +146,111 @@ int ff_veye_export_blockinfo_hevc(AVFrame *frame,
             int y_pu  = y << cb_to_pu;
             int pu    = x_pu + y_pu * min_pu_width;
             int cu_log2 = log2_ctb_size - depth;
+            const char *mvf = NULL;
+            int8_t pf = 0;
