+    int16_t  mv0_y;
+    int16_t  mv1_x;       ///< L1 motion vector, 1/4-pel luma (valid if PF_L1)
+    int16_t  mv1_y;
+    int8_t   ref0;        ///< L0 reference index, -1 if unused
+    int8_t   ref1;        ///< L1 reference index, -1 if unused
