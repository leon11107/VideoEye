+ * Serialize a libaom inspection frame (4x4 MI grid) into
+ * AV_FRAME_DATA_VEYE_BLOCKINFO and attach it to @p frame. @p fd must already
+ * have been filled by ifd_inspect(). Returns 0 on success/skip,
+ * AVERROR(ENOMEM) on allocation failure.
+ */
+int ff_veye_export_blockinfo_av1(AVFrame *frame,
+                                 const struct veye_insp_frame_data *fd);
+
 /*
  * HEVC cells are emitted at min-CB (typically 8x8) granularity. Unlike the
  * fixed-size H.264 macroblock, an HEVC coding unit spans a variable number
@@ -49,8 +83,15 @@ typedef struct VeyeBlockRecordHEVC {
     uint8_t  cu_log2;     ///< log2 of the luma CU size in pixels (3..6)
     uint8_t  pred;        ///< PredType: 1 intra, 2 inter, 3 skip, 4 pcm
