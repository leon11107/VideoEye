-                    ? *(const int8_t *)((const char *)mvf_pred_flag
-                                        + (size_t)pu * mvf_elem_size)
-                    : 0;
                 pred = (pf == 0) ? VEYE_PRED_INTRA : VEYE_PRED_INTER;
