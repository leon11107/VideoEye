 } VeyeBlockRecordHEVC;
 
 /**
@@ -83,23 +124,33 @@ int ff_veye_alloc_blockinfo_hevc(AVFrame *frame, int min_cb_width,
  * pre-allocated by ff_veye_alloc_blockinfo_hevc() (filling it in place) when
