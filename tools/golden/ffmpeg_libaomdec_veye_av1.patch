+    int8_t   ref1;        ///< ref_frame[1] (-1 if single-reference)
+    uint8_t  tx_size;     ///< libaom TX_SIZE
+    uint8_t  reserved;
+} VeyeBlockRecordAV1;
+
+struct veye_insp_frame_data;
+
