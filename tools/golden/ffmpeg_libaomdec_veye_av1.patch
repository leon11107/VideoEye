+    uint8_t  bsize;       ///< libaom BLOCK_SIZE enum (0..BLOCK_SIZES_ALL-1)
+    uint8_t  pred;        ///< PredType: 1 intra, 2 inter (AV1 has no skip/pcm class)
+    uint8_t  mode;        ///< libaom PREDICTION_MODE
