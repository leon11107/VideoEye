             if (cu_log2 < log2_min_cb_size) cu_log2 = log2_min_cb_size;
             if (cu_log2 > log2_ctb_size)    cu_log2 = log2_ctb_size;
 
+            if (tab_mvf && mvf_layout) {
+                mvf = (const char *)tab_mvf + (size_t)pu * mvf_elem_size;
+                pf  = *(const int8_t *)(mvf + mvf_layout->flag_off);
