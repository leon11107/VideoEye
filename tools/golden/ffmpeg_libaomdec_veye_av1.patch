diff --git a/libavcodec/veye_aom_inspect.h b/libavcodec/veye_aom_inspect.h
new file mode 100644
index 0000000..03673d4
--- /dev/null
+++ b/libavcodec/veye_aom_inspect.h
@@ -0,0 +1,79 @@
+/*
+ * VideoEye: layout mirror of libaom's bitstream-inspection structs.
+ *
+ * These mirror av1/decoder/inspection.h from the libaom that this FFmpeg is
+ * linked against. ifd_inspect() writes into a frame_data by the *real* struct
+ * layout, so this copy must stay byte-identical to it. It is valid only for a
+ * libaom built with CONFIG_INSPECTION=1 and CONFIG_ACCOUNTING=0 (the VideoEye
+ * build): with accounting on, the real insp_frame_data gains a leading
+ * Accounting* member and the layouts diverge.
+ *
+ * The structs are copied (rather than including the internal header) so this
+ * file does not drag in libaom's internal header web; only ifd_init/inspect/
+ * clear are referenced, which libaom.a exports.
+ */
+
+#ifndef AVCODEC_VEYE_AOM_INSPECT_H
+#define AVCODEC_VEYE_AOM_INSPECT_H
+
+#include <stdint.h>
+
+#define VEYE_AOM_MAX_SEGMENTS 8  /* MAX_SEGMENTS in av1/common/seg_common.h */
+
+typedef struct veye_insp_mv {
+    int16_t row;
+    int16_t col;
+} veye_insp_mv;
+
+typedef struct veye_insp_mi_data {
+    veye_insp_mv mv[2];
+    int16_t ref_frame[2];
+    int16_t mode;
+    int16_t uv_mode;
+    int16_t bsize;
+    int16_t skip;
+    int16_t segment_id;
+    int16_t dual_filter_type;
+    int16_t filter[2];
+    int16_t tx_type;
+    int16_t tx_size;
+    int16_t cdef_level;
+    int16_t cdef_strength;
+    int16_t cfl_alpha_idx;
+    int16_t cfl_alpha_sign;
+    int16_t current_qindex;
+    int16_t compound_type;
+    int16_t motion_mode;
+    int16_t intrabc;
+    int16_t palette;
+    int16_t uv_palette;
+} veye_insp_mi_data;
+
+typedef struct veye_insp_frame_data {
+    veye_insp_mi_data *mi_grid;
+    int16_t frame_number;
+    int show_frame;
+    int frame_type;
+    int base_qindex;
+    int mi_rows;
+    int mi_cols;
+    int tile_mi_rows;
+    int tile_mi_cols;
+    int16_t y_dequant[VEYE_AOM_MAX_SEGMENTS][2];
+    int16_t u_dequant[VEYE_AOM_MAX_SEGMENTS][2];
+    int16_t v_dequant[VEYE_AOM_MAX_SEGMENTS][2];
+    int delta_q_present_flag;
+    int delta_q_res;
+    int show_existing_frame;
+} veye_insp_frame_data;
+
+/* Exported by libaom.a (CONFIG_INSPECTION=1). The real prototypes use
+ * insp_frame_data*; the linker matches on symbol name, and the layout above
+ * is identical, so the veye_-prefixed pointer types are ABI-compatible. */
+extern void ifd_init(veye_insp_frame_data *fd, int frame_width,
+                     int frame_height);
+extern void ifd_clear(veye_insp_frame_data *fd);
+extern int  ifd_inspect(veye_insp_frame_data *fd, void *decoder,
+                        int skip_not_transform);
+
+#endif /* AVCODEC_VEYE_AOM_INSPECT_H */
